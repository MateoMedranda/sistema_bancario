# General
NODE_ENV=
FRONTEND_URL=

# Puertos HTTP de cada microservicio
USUARIOS_PORT=
CUENTAS_PORT=
TRANSACCIONES_PORT=

# Base de datos PostgreSQL
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE_USUARIOS=
DB_DATABASE_CUENTAS=
DB_DATABASE_TRANSACCIONES=
DB_SSL=
DB_SSL_REJECT_UNAUTHORIZED=

# En desarrollo puedes dejar true para crear tablas automaticamente.
# En produccion usa migraciones y cambia a false.
DB_SYNCHRONIZE=
DB_LOGGING=

# Carga datos demo si la base esta vacia al iniciar el servicio de clientes.
DB_SEED_DEMO=
